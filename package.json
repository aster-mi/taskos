{
  "name": "taskos",
  "version": "0.1.0",
  "description": "AI-first local task hub",
  "type": "module",
  "bin": {
    "taskos": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "node --experimental-sqlite --import tsx/esm src/cli.ts",
    "typecheck": "tsc --project tsconfig.test.json",
    "lint": "eslint src tests",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "ci": "npm run typecheck && npm run lint && npm run test && npm run build"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "nanoid": "^5.0.7"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^10.1.0",
    "tsup": "^8.0.2",
    "tsx": "^4.7.1",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.2"
  }
}
