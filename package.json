{
  "name": "taskos",
  "version": "0.1.0",
  "description": "AI-first local task hub",
  "type": "module",
  "bin": {
    "taskos": "./bin/taskos"
  },
  "scripts": {
    "build": "npm run build:web && tsup",
    "build:web": "cd web && npm install && npm run build",
    "dev": "node --experimental-sqlite --import tsx/esm src/cli.ts",
    "typecheck": "tsc --project tsconfig.test.json",
    "lint": "eslint src tests",
    "test": "vitest run",
    "test:web": "cd web && npm test",
    "test:all": "npm test && npm run test:web",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "ci": "npm run typecheck && npm run lint && npm run test && npm run build"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "cors": "^2.8.5",
    "express": "^4.18.3",
    "nanoid": "^5.0.7"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^10.1.0",
    "supertest": "^7.1.4",
    "tsup": "^8.0.2",
    "tsx": "^4.7.1",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.2"
  }
}
